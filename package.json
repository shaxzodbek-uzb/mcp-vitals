{
  "name": "mcp-vitals",
  "version": "0.1.0",
  "description": "Vital signs for your MCP server: inspect capabilities, benchmark tool-call latency (p50/p95/p99), and assert health in CI. The ab/k6/pytest for MCP servers — non-interactive, scriptable, LLM-free.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "benchmark",
    "latency",
    "load-test",
    "ci",
    "cli",
    "inspector",
    "anthropic",
    "claude",
    "devtools",
    "p95",
    "observability"
  ],
  "type": "module",
  "bin": {
    "mcp-vitals": "bin/mcp-vitals.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin",
    "schema",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "pretest": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/cli.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "execa": "^9.5.2",
    "globals": "^15.15.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  },
  "author": "Shaxzodbek Qambaraliyev <shaxzodbek@blaze.uz>",
  "license": "MIT",
  "homepage": "https://github.com/shaxzodbek-uzb/mcp-vitals#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shaxzodbek-uzb/mcp-vitals.git"
  },
  "bugs": {
    "url": "https://github.com/shaxzodbek-uzb/mcp-vitals/issues"
  }
}
